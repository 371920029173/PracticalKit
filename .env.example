# Canonical site URL (no trailing slash). Required for production SEO (sitemap, OG, JSON-LD).
# Example: https://mytoolkit.dev
NEXT_PUBLIC_SITE_URL=https://example.com

# Google Analytics 4 — set in Cloudflare Pages (or local .env) at build time.
# Leave empty to disable analytics and the cookie banner.
NEXT_PUBLIC_GA_ID=

# Plausible (privacy-friendly page views). Set domain only; no cookie banner required.
# Cloudflare Pages → Settings → Environment variables (Production + Preview).
# Self-host: set NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL to your script URL, e.g. https://stats.example.com/js/script.js
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=

# Google Search Console HTML tag verification (optional).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# One-command deploy (after `npx wrangler login` once): npm run deploy:pages
# Must match your Cloudflare Pages project name (see wrangler.toml name = "...").
